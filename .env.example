# Intelligent Analyst Enterprise — Environment Variables
# Copy to .env and fill in values. Never commit .env!

# Environment
ENVIRONMENT=development
TESTING=false

# Google Cloud
GCP_PROJECT=your-gcp-project-id
FIRESTORE_PROJECT=your-gcp-project-id
GCS_BUCKET=ia-us-central1-source-documents

# Auth (choose one: jwks or firebase)
AUTH_PROVIDER=jwks
JWKS_URL=https://your-idp.com/.well-known/jwks.json
JWKS_CACHE_TTL=300
AUTH_AUDIENCE=https://api.your-domain.com
AUTH_ISSUER=https://your-idp.com/

# LLM
ANTHROPIC_API_KEY=sk-ant-...
LLM_PRIMARY_PROVIDER=anthropic
LLM_PRIMARY_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
