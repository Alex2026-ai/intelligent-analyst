# US-TEST Environment - US internal stress testing only
# Points to your internal test backend (DEMO_MODE=false)
# Uploads enabled, no banner, trace IDs: BATCH-*

VITE_API_BASE_URL=https://YOUR_CLOUD_RUN_SERVICE_URL
VITE_ENVIRONMENT=US-TEST

VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_PROJECT_NUMBER
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
